# ───────────────────────────────────────────────────────────────────────
# PatchParty — environment
# Copy to .env.local and fill in. Deploy: set the same vars on Railway.
# ───────────────────────────────────────────────────────────────────────

# ── Model + sandbox ───────────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# https://app.daytona.io
DAYTONA_API_KEY=
# eu | us | asia — must match your Daytona org region.
DAYTONA_TARGET=eu

# ── Database ──────────────────────────────────────────────────────────
# Railway: attach the Postgres plugin and copy DATABASE_URL.
# Locally: `docker run -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16`
DATABASE_URL=postgresql://postgres:dev@localhost:5432/patchparty

# ── Auth.js v5 ────────────────────────────────────────────────────────
# `openssl rand -base64 32`
AUTH_SECRET=
# Absolute URL of the deployed app (used to compute OAuth callbacks in prod).
# Locally you can leave unset — Auth.js falls back to the request host.
AUTH_URL=http://localhost:3000

# GitHub OAuth App — create one at
# https://github.com/settings/developers  →  New OAuth App
#   Homepage URL:          http://localhost:3000     (or your production URL)
#   Authorization callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Cron / internal ───────────────────────────────────────────────────
# `openssl rand -hex 32` — shared secret for /api/cron/* endpoints.
CRON_SECRET=

# ── Legacy / fallback (only for local demos without full DB + OAuth) ──
# If set, and a request arrives without a session, the server falls back
# to this PAT. Leave EMPTY in production.
GITHUB_TOKEN=

# ── Public URL (client-side) ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
