# ───────────────────────────────────────────────────────────────────────
# PatchParty — environment
# Copy to .env.local and fill in. Deploy: set the same vars on Railway.
# ───────────────────────────────────────────────────────────────────────

# ── Model + sandbox ───────────────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# https://app.daytona.io
DAYTONA_API_KEY=
# eu | us | asia — must match your Daytona org region.
DAYTONA_TARGET=eu

# ── Database ──────────────────────────────────────────────────────────
# Railway: attach the Postgres plugin and copy DATABASE_URL.
# Locally: `docker run -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16`
DATABASE_URL=postgresql://postgres:dev@localhost:5432/patchparty

# ── Auth.js v5 ────────────────────────────────────────────────────────
# `openssl rand -base64 32`
AUTH_SECRET=
# Absolute URL of the deployed app (used to compute OAuth callbacks in prod).
# Locally you can leave unset — Auth.js falls back to the request host.
AUTH_URL=http://localhost:3000
# Required in prod when behind a reverse proxy (Railway, Vercel, etc.) —
# otherwise Auth.js rejects the host mismatch.
AUTH_TRUST_HOST=true

# GitHub OAuth App — create one at
# https://github.com/settings/developers  →  New OAuth App
#   Homepage URL:          http://localhost:3000     (or your production URL)
#   Authorization callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ── Cron / internal ───────────────────────────────────────────────────
# `openssl rand -hex 32` — shared secret for /api/cron/* endpoints.
CRON_SECRET=

# ── BYOK encryption ──────────────────────────────────────────────────
# `openssl rand -hex 32` — master secret for encrypting user-supplied
# Anthropic keys (AES-256-GCM with HKDF-SHA256 derivation).
# MUST be set before any user enters a BYOK key. Rotating this value
# invalidates all stored keys — users must re-enter.
BYOK_ENCRYPTION_KEY=

# ── Legacy / fallback (only for local demos without full DB + OAuth) ──
# If set, and a request arrives without a session, the server falls back
# to this PAT. Leave EMPTY in production.
GITHUB_TOKEN=

# ── Rate limiting (Upstash Redis) ─────────────────────────────────────
# Optional. When set, enforces 4 chat turns / 60s per user (sliding window).
# When unset, the limit is a no-op — fine for local dev, NOT for prod.
# https://console.upstash.com/redis → REST URL + REST Token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Preview proxy allowlist ───────────────────────────────────────────
# Optional. Comma-separated hostname suffixes the preview proxy may
# fetch from. Defaults to Daytona's current + historical preview
# domains (.daytonaproxy01.net, .daytona.work, .daytona.app,
# .daytona.io). Set this only if you run self-hosted Daytona or
# Daytona has moved to yet another domain.
# DAYTONA_PREVIEW_HOST_SUFFIXES=.daytonaproxy01.net,.daytona.work,.daytona.app,.daytona.io

# ── Public URL (client-side) ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
