# Copy to .env.local and fill in

# Anthropic API Key - get from console.anthropic.com
ANTHROPIC_API_KEY=

# Daytona API Key - get from app.daytona.io
DAYTONA_API_KEY=

# GitHub OAuth App (create at github.com/settings/developers)
# For hackathon simplicity, you can use a Personal Access Token instead (skip OAuth flow)
GITHUB_TOKEN=

# Public URL of deployed app (needed for GitHub OAuth callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000
